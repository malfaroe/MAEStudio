<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="M STUDIO"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabIndicatorColor="@color/text_primary">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOCUS"/>
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOG"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- ══ FOCUS tab ══ -->
    <ScrollView
        android:id="@+id/focusContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ TABATA ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TABATA"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="14dp"/>

                <!-- Config (visible when idle) -->
                <LinearLayout
                    android:id="@+id/configSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <!-- Work row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Trabajo"
                            android:textColor="@color/work"
                            android:textSize="15sp"/>
                        <Button
                            android:id="@+id/btnWorkMinus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="-"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:id="@+id/tvWorkVal"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="5"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <Button
                            android:id="@+id/btnWorkPlus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="min"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                    <!-- Rest row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Descanso"
                            android:textColor="@color/rest"
                            android:textSize="15sp"/>
                        <Button
                            android:id="@+id/btnRestMinus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="-"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:id="@+id/tvRestVal"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <Button
                            android:id="@+id/btnRestPlus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="min"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                    <!-- Cycles row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ciclos"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"/>
                        <Button
                            android:id="@+id/btnCycMinus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="-"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:id="@+id/tvCyclesVal"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="5"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <Button
                            android:id="@+id/btnCycPlus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+"
                            android:textSize="20sp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Running (visible when active) -->
                <LinearLayout
                    android:id="@+id/runningSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvPhase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRABAJO"
                        android:textColor="@color/work"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/work"
                        android:textSize="64sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/tvCycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ciclo 1 / 5"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnTabata"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="INICIAR"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/btn_start"/>
            </LinearLayout>

            <!-- ══ METRÓNOMO ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_bg"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="METRÓNOMO"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <!-- Left: -5 / -1 / -0.1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <Button
                            android:id="@+id/btnBpm5Minus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="-5"
                            android:textSize="14sp"
                            android:textColor="@color/bpm"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button
                            android:id="@+id/btnBpm1Minus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="-1"
                            android:textSize="14sp"
                            android:textColor="@color/bpm"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button
                            android:id="@+id/btnBpmD1Minus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="-0.1"
                            android:textSize="12sp"
                            android:textColor="@color/bpm"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>

                    <!-- Center: BPM value -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvBpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="120.0"
                            android:textColor="@color/bpm"
                            android:textSize="52sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BPM"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:letterSpacing="0.15"/>
                    </LinearLayout>

                    <!-- Right: +5 / +1 / +0.1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <Button
                            android:id="@+id/btnBpm5Plus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="+5"
                            android:textSize="14sp"
                            android:textColor="@color/bpm"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button
                            android:id="@+id/btnBpm1Plus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="+1"
                            android:textSize="14sp"
                            android:textColor="@color/bpm"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button
                            android:id="@+id/btnBpmD1Plus"
                            android:layout_width="72dp"
                            android:layout_height="44dp"
                            android:text="+0.1"
                            android:textSize="12sp"
                            android:textColor="@color/bpm"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Volume slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOL"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:layout_marginEnd="8dp"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderVolume"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:value="85"
                        android:stepSize="1"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnMetro"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="INICIAR"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/btn_start"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══ LOG tab ══ -->
    <FrameLayout
        android:id="@+id/logContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Column headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/section_bg"
                android:paddingEnd="8dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="match_parent"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="EJERCICIO"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="wrap_content"
                    android:text="BPM"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="wrap_content"
                    android:text="META"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="%"
                    android:textColor="@color/rest"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NOTAS"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:letterSpacing="0.1"
                    android:paddingStart="4dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLog"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:contentDescription="Agregar ejercicio"
            app:srcCompat="@android:drawable/ic_input_add"/>
    </FrameLayout>

</LinearLayout>
